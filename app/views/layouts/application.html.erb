<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= content_for(:title) || "Smart Project Management System" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="utf-8"/>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= yield :head %>
</head>

<body>
  <% if user_signed_in? %>
    <header class="topbar">
      <div class="topbar__content">
        <div class="brand">💬 Smart Project Management System</div>
        <nav class="topbar__nav">
          <%= link_to "Dashboard", root_path, class: "active" %>
          <%= link_to "Projects", projects_path %>
          <a href="#">Team</a>
          <a href="#">Admin Panel</a>
        </nav>
        <div class="topbar__right">
          <span>Hi, <%= current_user.name %></span>
          <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "logout-btn" %>
        </div>
      </div>
    </header>

    <main class="app-shell">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  <% else %>
    <main class="auth-shell">
      <div class="auth-shell__box">
        <%= render "shared/flash" %>
        <%= yield %>
      </div>
    </main>
  <% end %>
</body>
</html>
