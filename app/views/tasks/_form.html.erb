<%= form_with(model: [@project, @task], local: true) do |form| %>
  <% if @task.errors.any? %>
    <div class="flash flash-error" style="margin-bottom:20px;">
      <span class="material-symbols-outlined">error</span>
      <span><%= pluralize(@task.errors.count, "error") %>: <%= @task.errors.full_messages.first %></span>
    </div>
  <% end %>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <div class="form-group" style="grid-column:1/-1;">
      <%= form.label :title, "Task Title", class: "form-label" %>
      <%= form.text_field :title, class: "form-control", placeholder: "What needs to be done?", autofocus: true %>
    </div>

    <div class="form-group" style="grid-column:1/-1;">
      <%= form.label :description, "Description", class: "form-label" %>
      <%= form.text_area :description, rows: 4, class: "form-control", placeholder: "Add more context..." %>
    </div>

    <div class="form-group">
      <%= form.label :due_date, "Due Date", class: "form-label" %>
      <%= form.date_field :due_date, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, Task.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :priority, "Priority", class: "form-label" %>
      <%= form.select :priority, Task.priorities.keys.map { |p| [p.humanize, p] }, {}, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :assigned_user_id, "Assign To", class: "form-label" %>
      <%= form.collection_select :assigned_user_id, @project.members, :id, :name, { prompt: "Unassigned" }, class: "form-control" %>
    </div>
  </div>

  <div style="display:flex;gap:10px;padding-top:8px;border-top:1px solid var(--border);margin-top:8px;">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", project_path(@project), class: "btn btn-secondary" %>
  </div>
<% end %>
