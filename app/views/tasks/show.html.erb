<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <h1 class="mb-2"><%= @task.title %></h1>
        <p class="text-muted mb-0"><%= @task.description.presence || "No additional details." %></p>
      </div>
      <div><%= status_badge(@task.status) %></div>
    </div>

    <div class="row mb-3">
      <div class="col-sm-6">
        <strong>Project</strong>
        <div><%= link_to @project.name, project_path(@project) %></div>
      </div>
      <div class="col-sm-6">
        <strong>Assigned user</strong>
        <div><%= @task.assigned_user&.name || "Unassigned" %></div>
      </div>
    </div>

    <div class="row mb-4">
      <div class="col-sm-6">
        <strong>Due date</strong>
        <div><%= @task.due_date.strftime("%B %d, %Y") %></div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Edit task", edit_project_task_path(@project, @task), class: "btn btn-primary" %>
      <%= link_to "Back to project", project_path(@project), class: "btn btn-outline-secondary" %>
      <%= button_to "Delete task", project_task_path(@project, @task), method: :delete, data: { confirm: "Delete this task?" }, class: "btn btn-danger" %>
    </div>
  </div>
</div>
