<!-- Page Header -->
<div class="page-header">
  <div>
    <h1 class="page-title">Welcome back, <%= current_user.name.split.first %> 👋</h1>
    <p class="page-subtitle">Here's what's happening with your projects today.</p>
  </div>
  <%= link_to new_project_path, class: "btn btn-primary btn-lg" do %>
    <span class="material-symbols-outlined">add</span>
    New Project
  <% end %>
</div>

<!-- Stat Cards -->
<div class="stat-grid" style="gap: 16px; margin-bottom: 24px;">
  <div class="stat-card" style="background: #f87171; padding: 16px 20px;">
    <div style="flex: 1;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <span class="material-symbols-outlined" style="font-size: 20px; opacity: 0.9;">calendar_today</span>
        <div style="font-size: 11px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;">Tasks Due Today</div>
      </div>
      <div style="font-size: 28px; font-weight: 800;"><%= @tasks_due_today %></div>
    </div>
  </div>

  <div class="stat-card" style="background: #3b82f6; padding: 16px 20px;">
    <div style="flex: 1;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <span class="material-symbols-outlined" style="font-size: 20px; opacity: 0.9;">assignment</span>
        <div style="font-size: 11px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;">Projects in Progress</div>
      </div>
      <div style="font-size: 28px; font-weight: 800;"><%= @projects.count { |p| p.status == 'active' } %></div>
    </div>
  </div>

  <div class="stat-card" style="background: #10b981; padding: 16px 20px;">
    <div style="flex: 1;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <span class="material-symbols-outlined" style="font-size: 20px; opacity: 0.9;">check_circle</span>
        <div style="font-size: 11px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;">Completed Tasks</div>
      </div>
      <div style="font-size: 28px; font-weight: 800;"><%= @completed_tasks_count %></div>
    </div>
  </div>

  <div class="stat-card" style="background: #8b5cf6; padding: 16px 20px;">
    <div style="flex: 1;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <span class="material-symbols-outlined" style="font-size: 20px; opacity: 0.9;">groups</span>
        <div style="font-size: 11px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;">Team Members</div>
      </div>
      <div style="font-size: 28px; font-weight: 800;"><%= @team_members_count %></div>
    </div>
  </div>
</div>

<!-- Main Dashboard Grid -->
<div style="display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start;">

  <!-- Left Side: Kanban Task Board -->
  <div style="display:flex;flex-direction:column;gap:24px;">
    <div class="pm-card">
      <div class="pm-card-header" style="border-bottom: none;">
        <span class="pm-card-title" style="font-size: 16px;">Task Board</span>
      </div>
      <div class="pm-card-body" style="padding: 16px; background: #f1f5f9; border-radius: 0 0 14px 14px;">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
          
          <!-- To Do Column -->
          <div>
            <div style="background: #334155; color: white; padding: 10px 14px; border-radius: 6px 6px 0 0; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 8px;">
              To-Do <span style="background: #f59e0b; width: 16px; height: 10px; display: inline-block; clip-path: polygon(0% 0%, 100% 0%, 80% 50%, 100% 100%, 0% 100%);"></span>
            </div>
            <div style="background: #e2e8f0; border-radius: 0 0 6px 6px; padding: 12px; min-height: 200px;">
              <% (@kanban_tasks['todo'] || []).each do |task| %>
                <div class="dashboard-task-card" style="border-left-color: #ef4444;">
                  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                    <%= link_to task.title, project_task_path(task.project, task), style: "font-size: 13px; font-weight: 700; color: inherit; flex: 1;" %>
                    <%= button_to project_move_task_path(task.project, task, status: 'in_progress'), method: :patch, class: "btn btn-ghost btn-sm", style: "padding: 2px; height: auto;", title: "Start Task" do %>
                      <span class="material-symbols-outlined" style="font-size: 16px; color: #3b82f6;">play_arrow</span>
                    <% end %>
                  </div>
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <%= priority_badge(task.priority) %>
                    <div style="width: 20px; height: 20px; background: #f59e0b; border-radius: 4px; display: grid; place-items: center; font-size: 9px; font-weight: bold; color: white;" title="<%= task.assigned_user&.name %>">
                      <%= initials(task.assigned_user&.name || "U") %>
                    </div>
                  </div>
                </div>
              <% end %>
              <% if (@kanban_tasks['todo'] || []).empty? %>
                <div style="text-align: center; color: var(--text-muted); font-size: 11px; padding-top: 20px;">No tasks</div>
              <% end %>
            </div>
          </div>

          <!-- In Progress Column -->
          <div>
            <div style="background: #334155; color: white; padding: 10px 14px; border-radius: 6px 6px 0 0; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 8px;">
              In Progress <span style="background: #3b82f6; width: 16px; height: 10px; display: inline-block; clip-path: polygon(0% 0%, 100% 0%, 80% 50%, 100% 100%, 0% 100%);"></span>
            </div>
            <div style="background: #e2e8f0; border-radius: 0 0 6px 6px; padding: 12px; min-height: 200px;">
              <% (@kanban_tasks['in_progress'] || []).each do |task| %>
                <div class="dashboard-task-card" style="border-left-color: #3b82f6;">
                  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                    <%= link_to task.title, project_task_path(task.project, task), style: "font-size: 13px; font-weight: 700; color: inherit; flex: 1;" %>
                    <%= button_to project_move_task_path(task.project, task, status: 'completed'), method: :patch, class: "btn btn-ghost btn-sm", style: "padding: 2px; height: auto;", title: "Finish Task" do %>
                      <span class="material-symbols-outlined" style="font-size: 16px; color: #10b981;">check</span>
                    <% end %>
                  </div>
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span class="badge" style="background: #3b82f6; color: white; font-size: 9px; padding: 2px 6px;">DUE <%= task.due_date.strftime("%b %d").upcase %></span>
                    <div style="width: 20px; height: 20px; background: #f59e0b; border-radius: 4px; display: grid; place-items: center; font-size: 9px; font-weight: bold; color: white;" title="<%= task.assigned_user&.name %>">
                      <%= initials(task.assigned_user&.name || "U") %>
                    </div>
                  </div>
                </div>
              <% end %>
              <% if (@kanban_tasks['in_progress'] || []).empty? %>
                <div style="text-align: center; color: var(--text-muted); font-size: 11px; padding-top: 20px;">No tasks</div>
              <% end %>
            </div>
          </div>

          <!-- Done Column -->
          <div>
            <div style="background: #334155; color: white; padding: 10px 14px; border-radius: 6px 6px 0 0; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 8px;">
              Done <span style="background: #22c55e; width: 16px; height: 10px; display: inline-block; clip-path: polygon(0% 0%, 100% 0%, 80% 50%, 100% 100%, 0% 100%);"></span>
            </div>
            <div style="background: #e2e8f0; border-radius: 0 0 6px 6px; padding: 12px; min-height: 200px;">
              <% (@kanban_tasks['completed'] || []).each do |task| %>
                <div class="dashboard-task-card" style="border-left-color: #22c55e; opacity: 0.8;">
                  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                    <%= link_to task.title, project_task_path(task.project, task), style: "font-size: 13px; font-weight: 700; color: inherit; flex: 1; text-decoration: line-through; opacity: 0.6;" %>
                    <%= button_to project_move_task_path(task.project, task, status: 'in_progress'), method: :patch, class: "btn btn-ghost btn-sm", style: "padding: 2px; height: auto;", title: "Re-open Task" do %>
                      <span class="material-symbols-outlined" style="font-size: 16px; color: #64748b;">undo</span>
                    <% end %>
                  </div>
                  <div style="display: flex; align-items: center; gap: 6px; font-size: 11px; color: #10b981; font-weight: 700;">
                    <span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span>
                    COMPLETED
                  </div>
                </div>
              <% end %>
              <% if (@kanban_tasks['completed'] || []).empty? %>
                <div style="text-align: center; color: var(--text-muted); font-size: 11px; padding-top: 20px;">No tasks</div>
              <% end %>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Active Projects Overview -->
    <div class="pm-card">
      <div class="pm-card-header">
        <span class="pm-card-title">Project Status</span>
        <%= link_to "View All Projects", projects_path, class: "btn btn-ghost btn-sm" %>
      </div>
      <div class="pm-card-body" style="padding: 0;">
        <% @projects.each do |project| %>
          <div style="padding: 12px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 16px;">
            <div style="width: 36px; height: 36px; border-radius: 8px; background: var(--indigo-600); display: grid; place-items: center; color: white; font-weight: 800; font-size: 12px;">
              <%= project.code[0..1].upcase %>
            </div>
            <div style="flex: 1;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                <span style="font-size: 14px; font-weight: 700;"><%= project.name %></span>
                <span style="font-size: 11px; color: var(--text-muted); font-weight: 600;"><%= project.progress_percentage %>% COMPLETE</span>
              </div>
              <div class="progress-bar-wrap" style="height: 6px; background: #e2e8f0;">
                <div class="progress-bar-fill" style="width: <%= project.progress_percentage %>%"></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Right Side: Deadlines & Notifications -->
  <div style="display:flex;flex-direction:column;gap:24px;">

    <!-- Upcoming Deadlines -->
    <div class="pm-card">
      <div class="pm-card-header" style="padding: 12px 16px;">
        <span class="pm-card-title" style="font-size: 14px; font-weight: 700;">Upcoming Deadlines</span>
        <div style="display: flex; gap: 8px; color: var(--text-muted);">
           <span class="material-symbols-outlined" style="font-size: 18px; cursor: pointer;">chevron_left</span>
           <span class="material-symbols-outlined" style="font-size: 18px; cursor: pointer;">chevron_right</span>
        </div>
      </div>
      <div style="padding: 8px 0;">
        <% upcoming = @recent_tasks.reject(&:done?).sort_by(&:due_date).first(4) %>
        <% if upcoming.any? %>
          <% upcoming.each do |task| %>
            <div style="padding: 10px 16px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid #f1f5f9;">
              <span class="material-symbols-outlined" style="font-size: 18px; color: #3b82f6;">check_circle</span>
              <div style="font-size: 13px; font-weight: 600; flex: 1;"><%= task.title %> - <span style="color: var(--text-muted); font-size: 12px; font-weight: 400;"><%= task.due_date.strftime("%b %d") %></span></div>
            </div>
          <% end %>
        <% else %>
          <div style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 12px;">No upcoming deadlines</div>
        <% end %>
      </div>
    </div>

    <!-- Notifications -->
    <div class="pm-card">
      <div class="pm-card-header" style="padding: 12px 16px;">
        <span class="pm-card-title" style="font-size: 14px; font-weight: 700;">Notifications</span>
        <div style="display: flex; gap: 8px; color: var(--text-muted);">
           <span class="material-symbols-outlined" style="font-size: 18px; cursor: pointer;">chevron_left</span>
           <span class="material-symbols-outlined" style="font-size: 18px; cursor: pointer;">chevron_right</span>
        </div>
      </div>
      <div style="padding: 8px 0;">
        <% if @recent_tasks.any? %>
          <% @recent_tasks.first(4).each do |task| %>
            <div style="padding: 10px 16px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid #f1f5f9;">
              <% icon, color = case task.status 
                 when 'completed' then ['add_circle', '#10b981'] 
                 when 'todo' then ['comment', '#3b82f6'] 
                 else ['error_outline', '#ef4444'] 
                 end %>
              <span class="material-symbols-outlined" style="font-size: 20px; color: <%= color %>;"><%= icon %></span>
              <div style="font-size: 12px; font-weight: 500; flex: 1;">
                <%= task.status == 'completed' ? "Task \"#{task.title}\" marked as completed" : "Task \"#{task.title}\" updated recently" %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 12px;">No notifications</div>
        <% end %>
      </div>
    </div>

  </div>
</div>
