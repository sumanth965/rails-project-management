<div class="d-flex flex-column flex-md-row justify-content-between align-items-start mb-4 gap-3">
  <div>
    <h1 class="mb-2"><%= @project.name %></h1>
    <div class="text-muted mb-2">Owned by <strong><%= @project.owner.name %></strong> · Deadline <strong><%= @project.deadline.strftime("%b %d, %Y") %></strong></div>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <div class="project-info-box">
        <strong>Code</strong>
        <div class="info-value"><%= @project.code %></div>
      </div>
      <div class="project-info-box">
        <strong>Progress</strong>
        <div class="info-value"><%= @project.progress_percentage %>%</div>
      </div>
      <% if @project.overdue_tasks.any? %>
        <div class="project-info-box project-info-box--alert">
          <strong>Overdue</strong>
          <div class="info-value"><%= @project.overdue_tasks.count %></div>
        </div>
      <% end %>
    </div>
    <%= link_to "New Task", new_project_task_path(@project), class: "btn btn-primary" %>
  </div>
</div>

<div class="row gy-4">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5">Project details</h2>
        <p class="text-muted"><%= @project.description.presence || "No description provided." %></p>
        <div class="mb-3"><%= status_badge(@project.status) %></div>
        <% if @project.tasks.any? %>
          <div class="mb-3">
            <div class="progress" style="height: 14px;">
              <div class="progress-bar bg-success" role="progressbar" style="width: <%= @project.progress_percentage %>%" aria-valuenow="<%= @project.progress_percentage %>" aria-valuemin="0" aria-valuemax="100">
                <%= @project.progress_percentage %>% complete
              </div>
            </div>
          </div>
        <% end %>
        <div class="row">
          <div class="col-sm-6 mb-3">
            <strong>Deadline</strong>
            <div><%= @project.deadline.strftime("%B %d, %Y") %></div>
          </div>
          <div class="col-sm-6 mb-3">
            <strong>Team members</strong>
            <div><%= pluralize(@project.members.count, "member") %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mt-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="h5">Tasks</h2>
          <span class="badge bg-secondary">Total <%= @project.tasks.count %></span>
        </div>

        <div class="row row-cols-1 row-cols-sm-3 g-3 mb-4">
          <div class="col">
            <div class="card border-0 bg-light h-100">
              <div class="card-body p-3">
                <strong>To do</strong>
                <div class="fs-4"><%= @project.tasks.todo.count %></div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="card border-0 bg-light h-100">
              <div class="card-body p-3">
                <strong>In progress</strong>
                <div class="fs-4"><%= @project.tasks.in_progress.count %></div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="card border-0 bg-light h-100">
              <div class="card-body p-3">
                <strong>Done</strong>
                <div class="fs-4"><%= @project.tasks.done.count %></div>
              </div>
            </div>
          </div>
        </div>

        <% if @project.tasks.any? %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Status</th>
                  <th>Due</th>
                  <th>Owner</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @project.tasks.order(:due_date).each do |task| %>
                  <tr>
                    <td><%= link_to task.title, project_task_path(@project, task) %></td>
                    <td>
                      <%= status_badge(task.status) %>
                      <% if task.overdue? %>
                        <span class="badge bg-danger ms-1">Overdue</span>
                      <% end %>
                    </td>
                    <td><%= task.due_date.strftime("%b %d") %></td>
                    <td><%= task.assigned_user&.name || "Unassigned" %></td>
                    <td class="text-end">
                      <%= link_to "Edit", edit_project_task_path(@project, task), class: "btn btn-sm btn-outline-secondary" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="alert alert-light mb-0">No tasks added yet. Use the New Task button to start tracking work.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5">Team</h2>
        <% if @project.project_memberships.any? %>
          <ul class="list-group list-group-flush">
            <% @project.project_memberships.includes(:user).order("users.name").each do |membership| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= membership.user.name %></span>
                <span class="badge bg-primary">
                  <%= membership.role.humanize %>
                  <% if membership.user == @project.owner %>
                    · Owner
                  <% end %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-muted">No members assigned.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
