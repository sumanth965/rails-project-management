<% content_for :page_title, "Project Overview" %>

<!-- Header -->
<div class="page-header">
  <div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
      <%= link_to projects_path, class: "btn btn-ghost btn-sm" do %>
        <span class="material-symbols-outlined">arrow_back</span>
      <% end %>
      <span class="badge" style="background:var(--indigo-50);color:var(--indigo-700);"><%= @project.code %></span>
      <%= status_badge(@project.status) %>
      <% if @project.overdue_tasks.any? %>
        <span class="badge badge-overdue">
          <span class="material-symbols-outlined" style="font-size:11px;">warning</span>
          <%= @project.overdue_tasks.count %> overdue
        </span>
      <% end %>
    </div>
    <h1 class="page-title"><%= @project.name %></h1>
    <p class="page-subtitle">
      Owned by <strong><%= @project.owner.name %></strong> &middot;
      Deadline <strong><%= @project.deadline.strftime("%b %d, %Y") %></strong>
    </p>
  </div>
  <div style="display:flex;gap:8px;">
    <%= link_to new_project_task_path(@project), class: "btn btn-primary" do %>
      <span class="material-symbols-outlined">add</span>
      New Task
    <% end %>
    <%= link_to edit_project_path(@project), class: "btn btn-secondary" do %>
      <span class="material-symbols-outlined">edit</span>
      Edit
    <% end %>
  </div>
</div>

<!-- Stats Row -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">
  <% [
    ["Total Tasks", @project.tasks.count, "task_alt", "#f8fafc", "#3a4db3"],
    ["Completion", "#{@project.progress_percentage}%", "check_circle", "#f0fdf4", "#16a34a"],
    ["To Do", @project.tasks.todo.count, "pending", "#fffbeb", "#d97706"],
    ["Overdue", @project.overdue_tasks.count, "error", "#fef2f2", "#dc2626"],
  ].each do |label, value, icon, bg, color| %>
    <div class="pm-card" style="padding:18px 20px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:38px;height:38px;background:<%= bg %>;border-radius:10px;display:grid;place-items:center;">
          <span class="material-symbols-outlined" style="color:<%= color %>;font-size:20px;"><%= icon %></span>
        </div>
        <div>
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);"><%= label %></div>
          <div style="font-size:22px;font-weight:800;color:var(--text-primary);"><%= value %></div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Main Grid -->
<div style="display:grid;grid-template-columns:1fr 300px;gap:24px;align-items:start;">
  
  <!-- Left: Description + Kanban -->
  <div style="display:flex;flex-direction:column;gap:24px;">

    <!-- Description Card -->
    <div class="pm-card">
      <div class="pm-card-header">
        <span class="pm-card-title">About this project</span>
        <div class="progress-bar-wrap" style="width:160px;">
          <div class="progress-bar-fill" style="width:<%= @project.progress_percentage %>%"></div>
        </div>
      </div>
      <div class="pm-card-body">
        <p style="color:var(--text-secondary);font-size:14px;line-height:1.7;margin-bottom:20px;">
          <%= @project.description.presence || "No description provided." %>
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <div class="form-label" style="margin-bottom:4px;">Deadline</div>
            <div style="font-weight:600;font-size:14px;"><%= @project.deadline.strftime("%B %d, %Y") %></div>
          </div>
          <div>
            <div class="form-label" style="margin-bottom:4px;">Team Size</div>
            <div style="font-weight:600;font-size:14px;"><%= pluralize(@project.members.count, "member") %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Kanban Board -->
    <div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
        <h2 class="section-title" style="margin-bottom:0;">Kanban Board</h2>
        <span style="font-size:12px;color:var(--text-muted);"><%= @project.tasks.count %> total tasks</span>
      </div>
      <div class="kanban-board">
        <% Task.statuses.keys.each do |status| %>
          <% tasks_in_col = @project.tasks.where(status: status).order(due_date: :asc) %>
          <% dot_color = case status when "todo" then "#94a3b8" when "in_progress" then "#3b82f6" else "#22c55e" end %>
          <div class="kanban-col">
            <div class="kanban-col__header">
              <div class="kanban-col__title">
                <span class="kanban-col__dot" style="background:<%= dot_color %>"></span>
                <%= status.humanize %>
              </div>
              <span class="kanban-col__count"><%= tasks_in_col.count %></span>
            </div>
            <div class="kanban-col__body">
              <% if tasks_in_col.any? %>
                <% tasks_in_col.each do |task| %>
                  <div class="task-card">
                    <div class="task-card__title">
                      <%= link_to task.title, project_task_path(@project, task), style: "color:inherit;" %>
                    </div>
                    <div class="task-card__meta">
                      <%= priority_badge(task.priority) %>
                      <span style="display:flex;align-items:center;gap:3px;">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span style="color:<%= task.overdue? ? 'var(--red)' : '' %>;font-weight:<%= task.overdue? ? '700' : '400' %>">
                          <%= task.due_date.strftime("%b %d") %>
                        </span>
                      </span>
                    </div>
                    <div class="task-card__actions">
                      <% Task.statuses.keys.each do |ts| %>
                        <% next if ts == status %>
                        <%= button_to project_move_task_path(@project, task, status: ts), method: :patch, class: "btn btn-ghost btn-sm" do %>
                          → <%= ts.humanize %>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <div class="kanban-empty">
                  <span class="material-symbols-outlined" style="font-size:28px;margin-bottom:6px;display:block;opacity:.4;">inbox</span>
                  Empty
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Full Task Table -->
    <% if @tasks.any? %>
      <div class="pm-card">
        <div class="pm-card-header">
          <span class="pm-card-title">All Tasks</span>
          <span class="badge badge-todo"><%= @tasks.count %> total</span>
        </div>
        <div style="overflow-x:auto;">
          <table class="pm-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Due</th>
                <th>Assigned</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @tasks.each do |task| %>
                <tr>
                  <td style="font-weight:600;"><%= link_to task.title, project_task_path(@project, task), style: "color:var(--indigo-700);" %></td>
                  <td><%= status_badge(task.status) %></td>
                  <td><%= priority_badge(task.priority) %></td>
                  <td style="color:<%= task.overdue? ? 'var(--red)' : 'inherit' %>;font-weight:<%= task.overdue? ? '700' : '400' %>">
                    <%= task.due_date.strftime("%b %d, %Y") %>
                  </td>
                  <td style="color:var(--text-secondary)"><%= task.assigned_user&.name || "—" %></td>
                  <td>
                    <%= link_to edit_project_task_path(@project, task), class: "btn btn-secondary btn-sm" do %>
                      <span class="material-symbols-outlined">edit</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Right Sidebar: Team -->
  <div>
    <div class="pm-card">
      <div class="pm-card-header">
        <span class="pm-card-title">
          <span class="material-symbols-outlined" style="font-size:17px;vertical-align:middle;margin-right:4px;">group</span>
          Team
        </span>
        <span class="badge badge-in-progress"><%= @project.members.count %></span>
      </div>
      <div style="padding:12px 0;">
        <% @project.project_memberships.includes(:user).order("users.name").each do |membership| %>
          <div style="padding:10px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);">
            <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#3a4db3,#7c3aed);display:grid;place-items:center;color:#fff;font-size:12px;font-weight:700;flex-shrink:0;">
              <%= membership.user.name[0].upcase %>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= membership.user.name %></div>
              <div style="font-size:11px;color:var(--text-muted)"><%= membership.role.humanize %></div>
            </div>
            <% if membership.user == @project.owner %>
              <span class="material-symbols-outlined" style="font-size:16px;color:#d97706;" title="Owner">verified</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Timeline -->
    <div class="pm-card" style="margin-top:20px;">
      <div class="pm-card-header"><span class="pm-card-title">Timeline</span></div>
      <div class="pm-card-body">
        <div style="display:flex;flex-direction:column;gap:12px;">
          <div style="display:flex;gap:10px;align-items:flex-start;">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--blue);margin-top:5px;flex-shrink:0;"></div>
            <div>
              <div style="font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.4px;">Created</div>
              <div style="font-size:13px;font-weight:600;"><%= @project.created_at.strftime("%b %d, %Y") %></div>
            </div>
          </div>
          <div style="display:flex;gap:10px;align-items:flex-start;">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--red);margin-top:5px;flex-shrink:0;"></div>
            <div>
              <div style="font-size:12px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.4px;">Deadline</div>
              <div style="font-size:13px;font-weight:600;"><%= @project.deadline.strftime("%b %d, %Y") %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
