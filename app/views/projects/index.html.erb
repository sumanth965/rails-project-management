<div class="row align-items-end mb-4">
  <div class="col-md-8">
    <h1 class="mb-2">Projects</h1>
    <p class="text-muted">Track active work, team members, deadlines, and task status.</p>
  </div>
  <div class="col-md-4 text-md-end">
    <%= link_to "New Project", new_project_path, class: "btn btn-primary btn-lg" %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-8">
    <%= form_with url: projects_path, method: :get, local: true, class: "row g-2" do |form| %>
      <div class="col">
        <%= form.text_field :q, value: @query, placeholder: "Search projects, descriptions, or codes", class: "form-control" %>
      </div>
      <div class="col-auto">
        <%= form.submit "Search", class: "btn btn-outline-primary" %>
      </div>
    <% end %>
  </div>
</div>

<% if @projects.any? %>
  <div class="row g-4">
    <% @projects.each do |project| %>
      <div class="col-md-6">
        <div class="card card-custom h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <h3 class="card-title"><%= link_to project.name, project_path(project), class: "stretched-link text-decoration-none" %></h3>
            <small class="text-muted d-block mb-2">Code: <%= project.code %></small>
            <p class="text-muted mb-3"><%= truncate(project.description, length: 120) %></p>
            <div class="mb-2">Owner: <strong><%= project.owner.name %></strong></div>
            <div class="mb-2">Deadline: <strong><%= project.deadline.strftime("%b %d, %Y") %></strong></div>
            <div class="mb-3"><%= status_badge(project.status) %></div>
            <div class="mb-2">
              <div class="progress" style="height: 14px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: <%= project.progress_percentage %>%" aria-valuenow="<%= project.progress_percentage %>" aria-valuemin="0" aria-valuemax="100">
                  <%= project.progress_percentage %>%
                </div>
              </div>
            </div>
            <% if project.overdue_tasks.count.positive? %>
              <div class="mb-2"><span class="badge bg-danger">Overdue <%= project.overdue_tasks.count %></span></div>
            <% end %>
            <div class="mt-auto d-flex justify-content-between align-items-center text-muted small">
              <span><%= pluralize(project.tasks.count, "task") %></span>
              <span><%= pluralize(project.members.count, "team member") %></span>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">
    No projects yet. Create the first project to start tracking tasks and deadlines.
  </div>
<% end %>
