<%= form_with(model: project, local: true) do |form| %>
  <% if project.errors.any? %>
    <div style="background: linear-gradient(135deg, #fee2e2, #fecaca); border: 2px solid #ef4444; border-radius: 12px; padding: 16px; margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
      <div style="width: 40px; height: 40px; background: #ef4444; border-radius: 10px; display: grid; place-items: center; flex-shrink: 0;">
        <span class="material-symbols-outlined" style="color: white; font-size: 22px;">error</span>
      </div>
      <div>
        <div style="font-weight: 700; color: #dc2626; margin-bottom: 4px;"><%= pluralize(project.errors.count, "error") %> prevented this project from being saved:</div>
        <div style="font-size: 13px; color: #991b1b;"><%= project.errors.full_messages.first %></div>
      </div>
    </div>
  <% end %>

  <div style="display: grid; gap: 24px;">
    
    <!-- Project Name -->
    <div>
      <%= form.label :name, "Project Name", class: "form-label", style: "display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 8px;" %>
      <div style="position: relative;">
        <span class="material-symbols-outlined" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; color: var(--text-muted);">folder</span>
        <%= form.text_field :name, class: "form-control", placeholder: "e.g. Apollo Initiative", autofocus: true, style: "width: 100%; padding: 14px 14px 14px 46px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 15px; font-weight: 500; transition: all 0.3s;" %>
      </div>
      <p style="font-size: 12px; color: var(--text-muted); margin-top: 6px; margin-bottom: 0;">Choose a clear, descriptive name for your project</p>
    </div>

    <!-- Description -->
    <div>
      <%= form.label :description, "Description", class: "form-label", style: "display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 8px;" %>
      <div style="position: relative;">
        <span class="material-symbols-outlined" style="position: absolute; left: 14px; top: 14px; font-size: 20px; color: var(--text-muted);">description</span>
        <%= form.text_area :description, rows: 5, class: "form-control", placeholder: "Describe the project goals, scope, and key objectives...", style: "width: 100%; padding: 14px 14px 14px 46px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.3s; resize: vertical;" %>
      </div>
      <p style="font-size: 12px; color: var(--text-muted); margin-top: 6px; margin-bottom: 0;">Provide context about what this project aims to achieve</p>
    </div>

    <!-- Deadline and Status Grid -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
      
      <!-- Deadline -->
      <div>
        <%= form.label :deadline, "Deadline", class: "form-label", style: "display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 8px;" %>
        <div style="position: relative;">
          <span class="material-symbols-outlined" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; color: var(--text-muted);">calendar_today</span>
          <%= form.date_field :deadline, class: "form-control", style: "width: 100%; padding: 14px 14px 14px 46px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.3s;" %>
        </div>
        <p style="font-size: 12px; color: var(--text-muted); margin-top: 6px; margin-bottom: 0;">Target completion date</p>
      </div>

      <!-- Status -->
      <div>
        <%= form.label :status, "Status", class: "form-label", style: "display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 8px;" %>
        <div style="position: relative;">
          <span class="material-symbols-outlined" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; color: var(--text-muted);">flag</span>
          <%= form.select :status, Project.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-control", style: "width: 100%; padding: 14px 14px 14px 46px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.3s; appearance: none; background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27currentColor%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-repeat: no-repeat; background-position: right 14px center; background-size: 16px; padding-right: 40px;" %>
        </div>
        <p style="font-size: 12px; color: var(--text-muted); margin-top: 6px; margin-bottom: 0;">Current project status</p>
      </div>
    </div>

    <!-- Team Members -->
    <div>
      <%= form.label :member_ids, "Assign Team Members", class: "form-label", style: "display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 8px;" %>
      <div style="position: relative;">
        <span class="material-symbols-outlined" style="position: absolute; left: 14px; top: 14px; font-size: 20px; color: var(--text-muted); z-index: 1;">groups</span>
        <%= form.collection_select :member_ids, User.order(:name), :id, :name, { prompt: "Select team members...", include_hidden: false }, { multiple: true, class: "form-control", style: "width: 100%; padding: 14px 14px 14px 46px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.3s; min-height: 140px;" } %>
      </div>
      <div style="background: linear-gradient(135deg, #dbeafe, #bfdbfe); border: 1px solid #93c5fd; border-radius: 10px; padding: 12px; margin-top: 8px; display: flex; align-items: center; gap: 10px;">
        <span class="material-symbols-outlined" style="font-size: 18px; color: #1e40af;">info</span>
        <p style="font-size: 12px; color: #1e3a8a; margin: 0; font-weight: 600;">Hold <kbd style="background: white; padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: 700; border: 1px solid #93c5fd;">Ctrl</kbd> / <kbd style="background: white; padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: 700; border: 1px solid #93c5fd;">Cmd</kbd> to select multiple members</p>
      </div>
    </div>

  </div>

  <!-- Action Buttons -->
  <div style="display: flex; gap: 12px; padding-top: 32px; margin-top: 32px; border-top: 2px solid #f1f5f9;">
    <%= form.submit "Create Project", class: "btn", style: "background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; display: flex; align-items: center; gap: 8px; padding: 14px 32px; border-radius: 12px; font-size: 15px; font-weight: 700; box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4); transition: all 0.3s; cursor: pointer;" %>
    <%= link_to projects_path, style: "background: #f3f4f6; color: var(--text-primary); border: none; display: flex; align-items: center; gap: 8px; padding: 14px 32px; border-radius: 12px; font-size: 15px; font-weight: 700; transition: all 0.3s; text-decoration: none;" do %>
      <span class="material-symbols-outlined" style="font-size: 18px;">close</span>
      Cancel
    <% end %>
  </div>
<% end %>

<style>
  .form-control:focus {
    border-color: #667eea !important;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1) !important;
    outline: none;
  }
  
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5) !important;
  }
  
  kbd {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
