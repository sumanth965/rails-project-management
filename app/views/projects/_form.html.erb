<%= form_with(model: project, local: true) do |form| %>
  <% if project.errors.any? %>
    <div class="flash flash-error" style="margin-bottom:20px;">
      <span class="material-symbols-outlined">error</span>
      <span><%= pluralize(project.errors.count, "error") %>: <%= project.errors.full_messages.first %></span>
    </div>
  <% end %>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <div class="form-group" style="grid-column:1/-1;">
      <%= form.label :name, "Project Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-control", placeholder: "e.g. Apollo Initiative", autofocus: true %>
    </div>

    <div class="form-group" style="grid-column:1/-1;">
      <%= form.label :description, "Description", class: "form-label" %>
      <%= form.text_area :description, rows: 4, class: "form-control", placeholder: "Describe the project goals and scope..." %>
    </div>

    <div class="form-group">
      <%= form.label :deadline, "Deadline", class: "form-label" %>
      <%= form.date_field :deadline, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, Project.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-control" %>
    </div>

    <div class="form-group" style="grid-column:1/-1;">
      <%= form.label :member_ids, "Assign Team Members", class: "form-label" %>
      <%= form.collection_select :member_ids, User.order(:name), :id, :name, { prompt: "Select members...", include_hidden: false }, { multiple: true, class: "form-control", style: "min-height:110px;" } %>
      <p style="font-size:12px;color:var(--text-muted);margin-top:6px;">Hold Ctrl / Cmd to select multiple members.</p>
    </div>
  </div>

  <div style="display:flex;gap:10px;padding-top:8px;border-top:1px solid var(--border);margin-top:8px;">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", projects_path, class: "btn btn-secondary" %>
  </div>
<% end %>
