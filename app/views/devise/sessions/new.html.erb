<div style="text-align:center;margin-bottom:32px;">
  <div style="display:inline-flex;align-items:center;gap:8px;margin-bottom:16px;">
    <div style="width:36px;height:36px;background:linear-gradient(135deg,#4f6ef7,#7c3aed);border-radius:10px;display:grid;place-items:center;">
      <span class="material-symbols-outlined" style="color:#fff;font-size:20px;font-variation-settings:'FILL' 1">dataset</span>
    </div>
    <span style="font-size:20px;font-weight:800;color:var(--text-primary);">Clariti PM</span>
  </div>
  <h2 style="font-size:26px;font-weight:800;letter-spacing:-.5px;margin-bottom:6px;">Welcome back</h2>
  <p style="color:var(--text-secondary);font-size:14px;">Sign in to your workspace</p>
</div>

<div class="pm-card" style="box-shadow:0 8px 32px rgba(0,0,0,.1);">
  <div class="pm-card-body">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, placeholder: "name@company.com", class: "form-control" %>
      </div>

      <div class="form-group">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
          <%= f.label :password, "Password", class: "form-label", style: "margin-bottom:0;" %>
          <% if devise_mapping.recoverable? %>
            <%= link_to "Forgot password?", new_password_path(resource_name), style: "font-size:12px;color:var(--indigo-700);font-weight:600;" %>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "form-control" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-group" style="display:flex;align-items:center;gap:8px;">
          <%= f.check_box :remember_me, style: "width:16px;height:16px;accent-color:var(--indigo-700);" %>
          <%= f.label :remember_me, "Keep me signed in", style: "font-size:13px;font-weight:500;cursor:pointer;margin-bottom:0;" %>
        </div>
      <% end %>

      <%= f.submit "Sign In", class: "btn btn-primary btn-lg", style: "width:100%;justify-content:center;margin-top:8px;" %>
    <% end %>

    <div style="text-align:center;margin-top:20px;padding-top:20px;border-top:1px solid var(--border);font-size:13px;color:var(--text-secondary);">
      Don't have an account?
      <%= link_to "Create one", new_registration_path(resource_name), style: "color:var(--indigo-700);font-weight:700;" %>
    </div>
  </div>
</div>
