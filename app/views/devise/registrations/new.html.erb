<div class="mb-8 text-center lg:text-left">
  <h2 class="font-headline text-3xl font-extrabold text-on-surface mb-2">Create Account</h2>
  <p class="text-on-surface-variant">Join Clariti PM and start managing your projects with clarity.</p>
</div>

<div class="bg-surface-container-lowest border border-outline-variant p-8 rounded-2xl shadow-xl glass-card">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div>
      <%= f.label :name, class: "block text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2" %>
      <%= f.text_field :name, placeholder: "John Doe", class: "w-full px-4 py-3 bg-surface-container-low border border-outline-variant rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary transition-all outline-none" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2" %>
      <%= f.email_field :email, placeholder: "name@company.com", class: "w-full px-4 py-3 bg-surface-container-low border border-outline-variant rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary transition-all outline-none" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2" %>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "w-full px-4 py-3 bg-surface-container-low border border-outline-variant rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary transition-all outline-none" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2" %>
      <%= f.password_field :password_confirmation, placeholder: "••••••••", class: "w-full px-4 py-3 bg-surface-container-low border border-outline-variant rounded-xl text-body-md focus:ring-2 focus:ring-secondary focus:border-secondary transition-all outline-none" %>
    </div>

    <%= f.submit "Create Account", class: "w-full bg-secondary hover:bg-secondary-container text-on-secondary py-3 px-6 rounded-xl font-bold shadow-lg shadow-secondary/20 active:scale-[0.98] transition-all flex justify-center items-center gap-2 cursor-pointer" %>
  <% end %>
</div>

<div class="mt-8 text-center">
  <p class="text-sm text-on-surface-variant font-medium">
    Already have an account? 
    <%= link_to "Sign in here", new_session_path(resource_name), class: "text-secondary font-bold hover:underline ml-1" %>
  </p>
</div>
