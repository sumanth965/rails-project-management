<% content_for :page_title, "Notifications" %>

<!-- Enhanced Header with Gradient -->
<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 20px; padding: 32px; margin-bottom: 32px; box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3); position: relative; overflow: hidden;">
  <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255, 255, 255, 0.1); border-radius: 50%; filter: blur(40px);"></div>
  <div style="position: absolute; bottom: -30px; left: -30px; width: 150px; height: 150px; background: rgba(255, 255, 255, 0.08); border-radius: 50%; filter: blur(30px);"></div>
  
  <div style="position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
    <div>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <div style="width: 56px; height: 56px; background: rgba(255, 255, 255, 0.2); border-radius: 14px; display: grid; place-items: center; backdrop-filter: blur(10px); position: relative;">
          <span class="material-symbols-outlined" style="color: white; font-size: 28px;">notifications</span>
          <div style="position: absolute; top: 8px; right: 8px; width: 10px; height: 10px; background: #ef4444; border-radius: 50%; border: 2px solid white;"></div>
        </div>
        <div>
          <h1 style="font-size: 32px; font-weight: 900; color: white; margin: 0; letter-spacing: -0.5px; text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);">Notifications</h1>
          <p style="font-size: 14px; color: rgba(255, 255, 255, 0.9); margin: 0; font-weight: 500;">Stay updated with workspace activity</p>
        </div>
      </div>
    </div>
    <div style="display: flex; gap: 10px;">
      <button class="btn" style="background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid rgba(255, 255, 255, 0.3); display: flex; align-items: center; gap: 6px; padding: 10px 20px; border-radius: 12px; font-size: 13px; font-weight: 700; backdrop-filter: blur(10px); transition: all 0.3s;">
        Mark all as read
      </button>
      <button class="btn" style="background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid rgba(255, 255, 255, 0.3); display: flex; align-items: center; gap: 6px; padding: 10px 16px; border-radius: 12px; font-size: 13px; font-weight: 700; backdrop-filter: blur(10px); transition: all 0.3s;">
        <span class="material-symbols-outlined" style="font-size: 18px;">settings</span>
      </button>
    </div>
  </div>
</div>

<!-- Enhanced Notifications Card -->
<div style="background: white; border-radius: 20px; box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08); overflow: hidden; border: 1px solid rgba(0, 0, 0, 0.05);">
  <div style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); padding: 24px; border-bottom: 1px solid rgba(0, 0, 0, 0.06);">
    <div style="display: flex; align-items: center; gap: 12px;">
      <div style="width: 44px; height: 44px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 12px; display: grid; place-items: center; box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);">
        <span class="material-symbols-outlined" style="color: white; font-size: 22px;">history</span>
      </div>
      <div>
        <h2 style="font-size: 18px; font-weight: 800; color: var(--text-primary); margin: 0;">Recent Activity</h2>
        <p style="font-size: 12px; color: var(--text-muted); margin: 0;">Latest updates from your workspace</p>
      </div>
    </div>
  </div>
  <div style="padding: 0;">
    <% if @notifications.any? %>
      <div class="notification-list">
        <% @notifications.each do |notif| %>
          <div class="notification-item <%= 'notification-item--unread' if notif[:unread] %>" 
               style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; gap: 16px; align-items: flex-start; transition: all 0.3s; <%= 'background: linear-gradient(135deg, rgba(102, 126, 234, 0.03), rgba(118, 75, 162, 0.03));' if notif[:unread] %>">
            
            <div style="
              width: 48px; height: 48px; border-radius: 14px; 
              display: grid; place-items: center; flex-shrink: 0;
              background: <%= 
                case notif[:type]
                when :task then 'linear-gradient(135deg, #dbeafe, #bfdbfe)'
                when :project then 'linear-gradient(135deg, #e0e7ff, #c7d2fe)'
                when :comment then 'linear-gradient(135deg, #dcfce7, #bbf7d0)'
                when :alert then 'linear-gradient(135deg, #fee2e2, #fecaca)'
                else 'linear-gradient(135deg, #f3f4f6, #e5e7eb)'
                end
              %>;
              box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);">
              <span class="material-symbols-outlined" style="font-size: 22px; color: <%=
                case notif[:type]
                when :task then '#3b82f6'
                when :project then '#6366f1'
                when :comment then '#10b981'
                when :alert then '#ef4444'
                else '#6b7280'
                end
              %>;">
                <%= 
                  case notif[:type]
                  when :task then 'assignment'
                  when :project then 'folder'
                  when :comment then 'chat_bubble'
                  when :alert then 'warning'
                  else 'notifications'
                  end
                %>
              </span>
            </div>

            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; gap: 12px;">
                <p style="font-size: 14px; font-weight: <%= notif[:unread] ? '700' : '500' %>; color: var(--text-primary); line-height: 1.5; margin: 0;">
                  <%= notif[:message] %>
                </p>
                <span style="font-size: 12px; color: var(--text-muted); font-weight: 600; white-space: nowrap;"><%= notif[:time] %></span>
              </div>
              <div style="display: flex; gap: 12px; align-items: center;">
                <button class="btn btn-ghost btn-sm" style="padding: 4px 12px; font-size: 12px; font-weight: 600; border-radius: 8px; background: #f8f9fa; color: var(--text-primary);">View details</button>
                <% if notif[:unread] %>
                  <button class="btn btn-ghost btn-sm" style="padding: 4px 12px; font-size: 12px; font-weight: 600; border-radius: 8px; background: linear-gradient(135deg, #dbeafe, #bfdbfe); color: #1e40af;">Mark as read</button>
                <% end %>
              </div>
            </div>

            <% if notif[:unread] %>
              <div style="width: 10px; height: 10px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 50%; margin-top: 8px; box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);"></div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 80px 24px;">
        <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #f3f4f6, #e5e7eb); border-radius: 50%; display: grid; place-items: center; margin: 0 auto 20px;">
          <span class="material-symbols-outlined" style="font-size: 40px; color: #9ca3af;">notifications_off</span>
        </div>
        <h3 style="font-size: 18px; font-weight: 800; color: var(--text-primary); margin-bottom: 8px;">No notifications</h3>
        <p style="font-size: 14px; color: var(--text-muted); margin: 0;">You're all caught up! We'll notify you when something happens.</p>
      </div>
    <% end %>
  </div>
</div>

<style>
  .notification-item:hover { 
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05)) !important;
    transform: translateX(4px);
  }
  .notification-item:last-child { border-bottom: none !important; }
</style>
